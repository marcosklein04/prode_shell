# Django
DJANGO_SECRET_KEY=cambiame-por-una-clave-secreta-larga-y-segura
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Base de datos PostgreSQL
DB_NAME=prode_shell
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS - orígenes permitidos (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# API de fútbol (API-Football / api-sports.io)
FOOTBALL_API_KEY=tu-api-key-aqui
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io

# ID del torneo en la API externa (Mundial 2026 = a confirmar)
FOOTBALL_API_LEAGUE_ID=1
FOOTBALL_API_SEASON=2026
